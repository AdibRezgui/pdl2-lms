{
  "title": "EduAI LMS — Overview",
  "uid": "eduai-lms-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Backend Status",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "up{job=\"eduai-backend\"}",
        "legendFormat": "Backend"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "green", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 2, "type": "stat", "title": "Requests / sec",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"eduai-backend\"}[1m]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "id": 3, "type": "stat", "title": "Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"eduai-backend\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"eduai-backend\"}[5m])) * 100",
        "legendFormat": "error %"
      }],
      "options": {
        "unit": "percent",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 2 },
            { "color": "red", "value": 5 }
          ]
        }
      }
    },
    {
      "id": 4, "type": "stat", "title": "JVM Heap Used",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"eduai-backend\"} / jvm_memory_max_bytes{area=\"heap\",job=\"eduai-backend\"} * 100",
        "legendFormat": "heap %"
      }],
      "options": { "unit": "percent" }
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Requests by Status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"eduai-backend\"}[2m]))",
        "legendFormat": "HTTP {{ status }}"
      }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Response Time (p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"eduai-backend\"}[5m])))",
        "legendFormat": "p99 {{ uri }}"
      }],
      "options": { "unit": "s" }
    },
    {
      "id": 7, "type": "timeseries", "title": "JVM Memory",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"eduai-backend\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\",job=\"eduai-backend\"}",
          "legendFormat": "Heap Max"
        }
      ],
      "options": { "unit": "bytes" }
    },
    {
      "id": 8, "type": "timeseries", "title": "Active DB Connections",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "hikaricp_connections_active{job=\"eduai-backend\"}",
        "legendFormat": "Active"
      }, {
        "expr": "hikaricp_connections_pending{job=\"eduai-backend\"}",
        "legendFormat": "Pending"
      }]
    }
  ]
}
