# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-this-to-a-secure-random-string-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://eduai_user:eduai_pass@localhost:5432/eduai_db
POSTGRES_USER=eduai_user
POSTGRES_PASSWORD=eduai_pass
POSTGRES_DB=eduai_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_pass@localhost:6379
REDIS_PASSWORD=redis_pass

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-...your-key-here
ANTHROPIC_API_KEY=sk-ant-...your-key-here

# ── Storage (optional) ────────────────────────────────────────────────────────
# S3_BUCKET=eduai-uploads
# S3_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Email (Spring Mail — backend) ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@eduai.tn
MAIL_PASSWORD=change-me-app-password
MAIL_FROM=noreply@eduai.tn

# ── Backend security / uploads ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
UPLOAD_DIR=/app/uploads
APP_BASE_URL=https://eduai.yourdomain.com
CORS_ORIGINS=https://eduai.yourdomain.com
